{{#if noData}}
  <div class="no-summary-message" style="margin-top: 2rem; text-align: center;">
    <h2>Start tracking your finances</h2>
    <p>Looks like you haven't added any income or expenses for {{month}} {{year}} yet.</p>
    <p>Once you do, we'll generate insights and a spending chart to help you manage your money smarter.</p>
    <p>Go ahead and add your income and expenses to get started!</p>
  </div>
{{else}}
  <h1>Monthly Summary - {{month}} {{year}}</h1>

  <div class="summary-totals">
    <p><strong>Total Income:</strong> ${{totalIncome}}</p>
    <p><strong>Fixed Expenses:</strong> ${{totalFixedExpenses}}</p>
    <p><strong>Variable Expenses:</strong> ${{totalVariableExpenses}}</p>
    <p><strong>Remaining Balance:</strong> ${{remainingBalance}}</p>
  </div>

  <div class="summary-bottom-section">
    <!-- Category Breakdown -->
    <div class="category-breakdown">
      <h2>Spending by Category</h2>
      {{#if breakdownByCategory.length}}
        <ul class="category-scroll-list">
          {{#each breakdownByCategory}}
            <li>{{category}}: ${{totalSpent}}</li>
          {{/each}}
        </ul>
      {{else}}
        <p>No spending records for this month.</p>
      {{/if}}
    </div>

    <!-- Pie Chart -->
    <div class="chart-section">
      <h2>Spending Distribution by Category</h2>
      {{#if breakdownByCategory.length}}
        <canvas id="spendingChart" style="max-width: 100%;"></canvas>
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>
          const chartData = {{{json breakdownByCategory}}};
          const labels = chartData.map(entry => entry.category);
          const values = chartData.map(entry => entry.totalSpent);

          const ctx = document.getElementById('spendingChart').getContext('2d');
          new Chart(ctx, {
            type: 'pie',
            data: {
              labels: labels,
              datasets: [{
                label: 'Spending by Category',
                data: values,
                backgroundColor: [
                  '#e6aebe',
                  '#f4cdd2',
                  '#c996a4',
                  '#f8b7c3',
                  '#eaa0a2'
                ]
              }]
            },
            options: {
              plugins: {
                legend: {
                  position: 'bottom',
                  labels: {
                    color: '#333',
                    font: {
                      size: 14,
                      family: "'Trebuchet MS', sans-serif"
                    }
                  }
                }
              }
            }
          });
        </script>
      {{else}}
        <p>No spending data available to visualize.</p>
      {{/if}}
    </div>

    <!-- Line Chart -->
    <div class="chart-section">
      <h2>Daily Spending Trend</h2>
      {{#if dailyExpenses.length}}
        <canvas id="dailyExpenseChart" style="max-width: 100%;"></canvas>
        <script>
          const dailyData = {{{json dailyExpenses}}};
          const dailyLabels = dailyData.map(entry => entry.day);
          const dailyValues = dailyData.map(entry => entry.total);

          const dailyCtx = document.getElementById('dailyExpenseChart').getContext('2d');
          new Chart(dailyCtx, {
            type: 'line',
            data: {
              labels: dailyLabels,
              datasets: [{
                label: 'Daily Expenses',
                data: dailyValues,
                fill: false,
                borderColor: '#c996a4',
                borderWidth: 2,
                tension: 0.3
              }]
            },
            options: {
              scales: {
                x: {
                  title: {
                    display: true,
                    text: 'Day of Month'
                  }
                },
                y: {
                  title: {
                    display: true,
                    text: 'Amount ($)'
                  },
                  beginAtZero: true
                }
              }
            }
          });
        </script>
      {{else}}
        <p>No daily expense data available.</p>
      {{/if}}
    </div>
  </div>
{{/if}}
